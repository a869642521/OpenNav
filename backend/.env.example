# JWT 签名密钥（生产请使用 openssl rand -base64 32 生成）
JWT_SECRET=your_jwt_secret_here

# 前端地址（CORS + QQ 登录成功后的跳转）
FRONTEND_URL=http://localhost:5173

# 后端对公网可访问的根 URL（QQ 回调用，须与 QQ 互联里填的回调域名一致）
# 本地开发一般为 http://localhost:3001
BACKEND_PUBLIC_URL=http://localhost:3001

# QQ 互联（https://connect.qq.com/）应用 APP ID 与 APP Key；不配置则隐藏 QQ 登录
QQ_APP_ID=
QQ_APP_KEY=

# ========== 邮箱验证码登录（POST /auth/email/otp/*）==========
# 开发：不设 SMTP 时，非 production 会自动返回 debugCode；生产可设 EMAIL_OTP_DEBUG=1 联调（勿长期开启）
# EMAIL_OTP_DEBUG=1
#
# 生产：NODE_ENV=production 且关闭 EMAIL_OTP_DEBUG 时须配置 SMTP，否则发信返回 503
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0          # 465 端口可设 1
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MyNav <noreply@example.com>"   # 可选，默认同 SMTP_USER

# ========== 短信验证码（手机登录）==========
# 开发/联调：可设 SMS_DEBUG=1，接口会返回 debugCode（切勿在生产长期开启）
# SMS_DEBUG=1
#
# 生产：NODE_ENV=production 且勿开 SMS_DEBUG。设置 SMS_PROVIDER=tencent 并填写下方
# TENCENT_SMS_* 后，POST /auth/phone/send 会调用腾讯云 SendSms；未配齐则返回 501。
#
# SMS_PROVIDER=tencent
#
# —— 腾讯云短信（必填项均非空时生效，依赖 npm 包 tencentcloud-sdk-nodejs）——
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_SDK_APP_ID=      # 短信应用 SDK AppId
# TENCENT_SMS_SIGN_NAME=       # 已审核签名
# TENCENT_SMS_TEMPLATE_ID=     # 验证码模板 ID，模板正文需含 {1} 为 6 位码
# TENCENT_SMS_REGION=ap-guangzhou
#
# —— 阿里云短信（示例）——
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=    # 模板 code，变量如 code
# ALIYUN_SMS_REGION=cn-hangzhou

# ========== Kimi 上游（用户在前端保存的 Key 由后端代请求）==========
#
# 【Kimi Coding Plan】在 .env 任选其一即可（不要同时用 Moonshot 默认）：
#   KIMI_USE_CODING_PLAN=1
# 或显式写基址：
#   KIMI_API_BASE_URL=https://api.kimi.com/coding/v1
# 模型可不设，默认 kimi-k2.5；若控制台另有可用名可设：
#   KIMI_MODEL=kimi-k2.5
#
# 【普通 Moonshot 控制台 sk- Key】OpenAI 协议，勿用 Coding 域名：
#   KIMI_API_BASE_URL=https://api.moonshot.cn/v1
#   KIMI_MODEL=moonshot-v1-8k
#
# 不设 KIMI_API_BASE_URL 且不设 KIMI_USE_CODING_PLAN 时 → 默认 api.moonshot.cn/v1
# Kimi Coding Plan 用户取消下面一行（或与 KIMI_API_BASE_URL 二选一）：
# KIMI_USE_CODING_PLAN=1
# KIMI_API_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL=kimi-k2.5
KIMI_API_KEY=

# ========== Brave Search API（学习库「搜索网络」功能）==========
# 注册地址：https://brave.com/search/api/
# 填入后，侧栏学习库「搜索网络」按钮将通过该 Key 代理查询真实搜索结果
# 不填则「搜索网络」功能不可用（返回 503）
# BRAVE_API_KEY=

# 数据库路径（SQLite）
DATABASE_URL=./data/nav.db

PORT=3001
