# Google OAuth 2.0 客户端 ID（与前端相同）
GOOGLE_CLIENT_ID=

# JWT 签名密钥（任意随机字符串，生产环境请使用 openssl rand -base64 32 生成）
JWT_SECRET=your_jwt_secret_here

# （可选）Kimi 接口基址（不要写 /chat/completions）
# 普通 Moonshot 控制台 Key：https://api.moonshot.cn/v1 或 https://api.moonshot.ai/v1
# Kimi Coding Plan / Kimi Code 的 Key 必须用：https://api.kimi.com/coding/v1
# 不设此项时，后端会依次尝试 moonshot.cn 与 coding 端点
# KIMI_API_BASE_URL=https://api.kimi.com/coding/v1

# （可选）AI 路由使用的模型 ID，默认 kimi-k2.5
# KIMI_MODEL=kimi-k2.5

# （已弃用 BYOK 模式）服务端统一 Key，一般留空
KIMI_API_KEY=

# 数据库路径（SQLite，开发用）
DATABASE_URL=./data/nav.db

# 服务器端口
PORT=3001

# 前端地址（CORS 白名单）
FRONTEND_URL=http://localhost:5173
